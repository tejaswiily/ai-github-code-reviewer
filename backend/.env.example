# Database Configuration
# Default local Postgres or Docker Compose Postgres container address
DATABASE_URL=postgresql://postgres:postgres@db:5432/codereview

# OpenAI API Key for LangChain integration
OPENAI_API_KEY=your_openai_api_key_here

# FastAPI Configuration
PORT=8000
HOST=0.0.8

# Guardrails to prevent long execution times and token exhaustion
MAX_FILES_TO_ANALYZE=20
